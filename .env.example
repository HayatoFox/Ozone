# Copier en `.env` et adapter. Toutes les variables sont optionnelles (valeurs par défaut indiquées).

# ── Serveur ──
OZONE_BIND=127.0.0.1:8080
OZONE_DB_PATH=ozone.db

# ── Identité de l'instance (appliquée au tout premier démarrage / bootstrap) ──
OZONE_INSTANCE_NAME=Mon Instance Ozone
OZONE_INSTANCE_DESCRIPTION=Une instance Ozone auto-hébergée
OZONE_REGISTRATION=open            # open | invite | closed

# Mot de passe d'instance (gate d'accès facultatif). Laisser vide = pas de gate.
# OZONE_INSTANCE_PASSWORD=change-moi

# ── Vocal (nœud média SFU, processus séparé `ozone-sfu`) ──
# Secret PARTAGÉ entre l'API et le SFU pour signer/vérifier les jetons vocaux.
# Doit être identique des deux côtés. Sans lui, le SFU refuse toute connexion (fail-closed)
# et l'API se rabat sur son secret JWT interne (le SFU ne pourra pas vérifier → vocal indisponible).
# Générer p.ex. avec : openssl rand -hex 32
# OZONE_VOICE_SECRET=
# OZONE_SFU_BIND=127.0.0.1:8081

# ── Journalisation ──
RUST_LOG=info

# ── Mode full-stack (non utilisé par le binaire tout-en-un SQLite — pour plus tard) ──
# DATABASE_URL=postgres://ozone:ozone@localhost:5432/ozone
# REDIS_URL=redis://localhost:6379
# NATS_URL=nats://localhost:4222
# S3_ENDPOINT=http://localhost:9000
