{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Permissions de la fenêtre principale du client Ozone.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://*" },
        { "url": "https://*/*" },
        { "url": "http://*" },
        { "url": "http://*/*" }
      ]
    }
  ]
}
