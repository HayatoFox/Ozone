{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ozone",
  "version": "0.1.0",
  "identifier": "com.ozone.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Ozone",
        "width": 1280,
        "height": 800,
        "minWidth": 940,
        "minHeight": 600,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "script-src": "'self'",
        "style-src": "'self' 'unsafe-inline'",
        "font-src": "'self' data:",
        "img-src": "'self' data: blob: https: http:",
        "media-src": "'self' data: blob: https: http:",
        "connect-src": "'self' ipc: http://ipc.localhost https: http: ws: wss: blob:"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/icon.ico",
      "icons/128x128.png",
      "icons/32x32.png"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
